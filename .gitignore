# Bevy
# Dynamic linking artifacts (used for fast iterative compiles via the `dynamic_linking` feature)
*.dll
*.dylib
*.so

# Generated/cached assets
/assets/**/*.meta
/imported_assets/

# Profiling / tracing output
*.profraw
*.trace
trace-*.json
tracy-capture-*.tracy

# WebAssembly / wasm-bindgen output (if targeting web)
/wasm/
/dist/
*.wasm

# Editor & IDE
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~

# rust-analyzer
rust-project.json

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets
.env
.env.local


